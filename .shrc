# ~/.shrc: interactive shells -*- shell-script -*-

# BACKGROUND
#
# Things that need to be done for every interactive login should be done
# here. Alternatively, things that only need to be done once when a user logs
# into the machine should be done in ~/.profile file.

if test -n "$BASH_VERSION" ; then
	_SHELL="bash"
elif test -n "$KSH_VERSION" ; then
	_SHELL="ksh"
elif test -n "$ZSH_VERSION" ; then
	_SHELL="zsh"
elif test -z "$PS3" ; then
	_SHELL="sh"
else
	_SHELL="unknown"
fi

# echo >&2 "$SHELL (interactive): running $HOME/.shrc: ($_SHELL)"

# POSIX-safe ensure HOSTNAME/HOST with whitespace check
HOSTNAME=$(uname -n)
HOST=$(printf '%s' "$HOSTNAME" | cut -d. -f1)
export HOSTNAME HOST

# TERMINAL ESCAPE SEQUENCES
#
# GNU Screen control sequences:
#   https://www.gnu.org/software/screen/manual/html_node/Control-Sequences.html
#
# xterm / console OSC sequences (ESC ] N ; txt ST):
#     0 - set icon name and window title   https://www.man7.org/linux/man-pages/man4/console_codes.4.html
#     1 - set icon name
#     2 - set window title
#     7 - report working directory         https://github.com/maconcg/osc7
#   133 - shell integration (A/B/C/D)      https://contour-terminal.org/vt-extensions/osc-133-shell-integration

# function osc () {
#     print -Pn "%{\e]${(j.;.)@}\e\\%}"
# }

set_gnu_screen_hardstatus_line () { printf "\e_%s\e\\" "$*"; } # Application Program Command (xterm window title also sets this)
set_gnu_screen_window_title () { printf "\ek%s\e\\" "$*"; }	   # Title Definition String

set_title_and_cwd () {
	# Preserve $? so PS1 sees the user's last command exit status, not our
	# own.
	local rc
	rc=$?
	printf "\e]0;%s@%s:%s\e\\" "$LOGNAME" "$HOSTNAME" "${PWD/#$HOME/~}"
	printf "\e]7;file://%s%s\e\\" "$HOSTNAME" "$PWD"
	return $rc
}

set_title_with_dirs () {
	case $TERM in
		gnome* | rxvt | tmux* | vt100 | xterm*)
			# append cwd enclosed in parens
			set_xterm_window_title "$* ($(dirs))"
			;;
		screen*)
			# use extra hardstatus line for dirs, instead of combining
			set_gnu_screen_hardstatus_line "$(dirs)"
			set_gnu_screen_window_title "$@"
			;;
		*)
			echo >&2 "set_title_with_dirs: cannot recognize TERM: [$TERM]"
			;;
	esac
}

set_xterm_window_title () { printf "\e]0;%s\e\\" "$*"; }

case $_SHELL in
	bash)
		# check the window size after each command and, if necessary, update
		# the values of LINES and COLUMNS.
		shopt -s checkwinsize

		# append to the history file rather than overwriting it.
		shopt -s histappend

		# enable programmable completion features (you don't need to enable
		# this, if it's already enabled in /etc/bash.bashrc and /etc/profile
		# sources /etc/bash.bashrc).
		if ! shopt -oq posix; then
			if [ -f /usr/share/bash-completion/bash_completion ]; then
				. /usr/share/bash-completion/bash_completion
			elif [ -f /etc/bash_completion ]; then
				. /etc/bash_completion
			fi
		fi

		# OSC-133 shell integration sequences - empty when inside Emacs, which
		# does not handle them.
		if [ -z "$INSIDE_EMACS" ] ; then
			_osc133_B='\[\e]133;B\e\\\]'                 # PROMPT END
			_osc133_C='\[\e]133;C\e\\\]'                 # OUTPUT BEGIN
			_osc133_DA='\[\e]133;D;$?\e\\\e]133;A\e\\\]' # OUTPUT END + PROMPT BEGIN
		else
			_osc133_B=''
			_osc133_C=''
			_osc133_DA=''
		fi

		PROMPT_COMMAND=set_title_and_cwd

		shell_prompt_fancy () {
			PS0="\[\e[2m\]# START: \D{%F}T\D{%T}\D{%Z}\[\e[22m\]\n${_osc133_C}"

			if [ -n "$HOSTPROMPT" ] ; then
				PS1="${_osc133_DA}\[\e[2m\]# FINISH: \D{%F}T\D{%T}\D{%Z}\[\e[22m\] [\[\$( _code=\$? ; if [ \$_code -eq 0 ] ; then echo \"\e[32m\$_code\e[39m\" ; else echo \"\e[1;31m\$_code\e[22;39m\" ; fi )\]]\n# \[\e[32m\]\u\[\e[39m\]@\[\e[36m\]${HOSTPROMPT}\[\e[39m\]:\[\e[33m\]\w\[\e[39m\]\n"
			else
				PS1="${_osc133_DA}\[\e[2m\]# FINISH: \D{%F}T\D{%T}\D{%Z}\[\e[22m\] [\[\$( _code=\$? ; if [ \$_code -eq 0 ] ; then echo \"\e[32m\$_code\e[39m\" ; else echo \"\e[1;31m\$_code\e[22;39m\" ; fi )\]]\n# \[\e[32m\]\u\[\e[39m\]@\[\e[36m\]\h\[\e[39m\]:\[\e[33m\]\w\[\e[39m\]\n"
			fi

			if which git_prompt >/dev/null 2>&1 ; then
				PS1="${PS1}\[\e[35m\]\$(git_prompt)\[\e[39m\]"
			fi

			PS1="${PS1}\$ ${_osc133_B}"
		}

		shell_prompt_sans_color () {
			PS0="# START: \D{%F}T\D{%T}\D{%Z}\n${_osc133_C}"
			PS1="${_osc133_DA}# FINISH: \D{%F}T\D{%T}\D{%Z} [\$?]\n# \u@\h:\w\n\$ ${_osc133_B}"
		}

		shell_prompt_with_color () {
			PS0="\[\e[2m\]# START: \D{%F}T\D{%T}\D{%Z}\[\e[22m\]\n${_osc133_C}"
			PS1="${_osc133_DA}\[\e[2m\]# FINISH: \D{%F}T\D{%T}\D{%Z}\[\e[22m\] [\[\$( _code=\$? ; if [ \$_code -eq 0 ] ; then echo \"\e[32m\$_code\e[39m\" ; else echo \"\e[1;31m\$_code\e[22;39m\" ; fi )\]]\n# \[\e[32m\]\u\[\e[39m\]@\[\e[36m\]\h\[\e[39m\]:\[\e[33m\]\w\[\e[39m\]\n\$ ${_osc133_B}"
		}

		shell_prompt_with_color
		;;

	ksh)
		_ksh_prompt_with_color () {
			printf "# \033[32m%s\033[39m@\033[36m%s\033[39m:\033[33m%s\033[39m\n" \
				   "$LOGNAME" "$HOST" "${PWD/#$HOME/\~}"
		}

		shell_prompt_sans_color () {
			PS1='# ${LOGNAME}@${HOST}:${PWD/#$HOME/\~}
$ '
		}

		shell_prompt_with_color () {
			PS1='$(_ksh_prompt_with_color)
$ '
		}

		shell_prompt_with_color
		;;

	sh) : ;;

	zsh)
		# OSC-133 shell integration sequences - empty when inside Emacs, which
		# does not handle them.
		if [ -z "$INSIDE_EMACS" ] ; then
			_osc133_B=$'%{\e]133;B\e\\%}'                 # PROMPT END
			_osc133_DA=$'%{\e]133;D;%?\e\\\e]133;A\e\\%}' # OUTPUT END + PROMPT BEGIN
		else
			_osc133_B=''
			_osc133_DA=''
		fi

		autoload -Uz add-zsh-hook

		# precmd: runs before each prompt - OSC-7 and window title.
		add-zsh-hook precmd set_title_and_cwd

		# preexec hooks: one per prompt style, swapped by shell_prompt_*
		# functions.
		_prompt_preexec_sans_color () {
			printf "# START: %s\n" "$(date +%FT%T%Z)"
			[ -n "$INSIDE_EMACS" ] || printf "\e]133;C\e\\"
		}

		_prompt_preexec_with_color () {
			printf "\e[2m# START: %s\e[22m\n" "$(date +%FT%T%Z)"
			[ -n "$INSIDE_EMACS" ] || printf "\e]133;C\e\\"
		}

		shell_prompt_sans_color () {
			add-zsh-hook -d preexec _prompt_preexec_with_color
			add-zsh-hook    preexec _prompt_preexec_sans_color
			PROMPT="${_osc133_DA}"$'# FINISH: %D{%FT%T%Z} [%(?,0,%?)]\n# %n@%m:%~\n'"${_osc133_B}"$'%# '
		}

		shell_prompt_with_color () {
			add-zsh-hook -d preexec _prompt_preexec_sans_color
			add-zsh-hook    preexec _prompt_preexec_with_color
			PROMPT="${_osc133_DA}"$'\e[2m# FINISH: %D{%FT%T%Z}\e[22m [%(?,\e[32m0\e[39m,\e[1;31m%?\e[22;39m)]\n# \e[32m%n\e[39m@\e[36m%m\e[39m:\e[33m%~\e[39m\n'"${_osc133_B}"$'%# '
		}

		shell_prompt_with_color
		;;

	*) echo >&2 "unrecognized shell: '${_SHELL}'" ;;
esac

[ "$_SHELL" = "sh" ] || hrg () { ( cd "$XDG_STATE_HOME/history" && exec rg "$*" ) }

# Make less more friendly for non-text input files, see lesspipe(1).
[ ! -x /usr/bin/lesspipe ] || eval "$(SHELL=/bin/sh /usr/bin/lesspipe)"

alias clip='xclip -selection clipboard'
alias dfh='df -h -x devtmpfs -x tmpfs --output=source,used,size,pcent,iused,itotal,ipcent,target'
alias git-head='git hl | head'
alias hlf='ls -hlF'
alias hist='histogram --fold --descending'
alias histr='histogram --fold --descending --raw'
alias histw='histogram --fold --descending --width 80'

# NOTE: The following aliases intentionally expand when defined rather than
# when used.
alias kill-emacs="pkill -u $LOGNAME emacs"
alias pg="pgrep -au $LOGNAME"

# enable color support of ls and also add handy aliases
if [ -x /usr/bin/dircolors ]; then
	if [ -r ~/.dircolors ] ; then
		eval "$(dircolors -b ~/.dircolors)"
	else
		eval "$(dircolors --sh)"
	fi
	alias ls='ls --color=auto'
	alias grep='grep --color=auto'
	alias fgrep='fgrep --color=auto'
	alias egrep='egrep --color=auto'
fi

hexl () { emacs -q -nw --eval "(hexl-find-file \"$1\")" ; }

dos2unix () { tr -d '\r' <"$1" >"$2" ; }
mac2unix () { tr '\r' '\n' <"$1" >"$2" ; }
unix2mac () { tr '\n' '\r' <"$1" >"$2" ; }
unix2dos () { ruby -pe '$_=$_.gsub(/$/, "\r")' <"$1" >"$2" ; }

[ ! -r "$HOME/.cargo/env" ] || . "$HOME/.cargo/env"

# [ "$_SHELL" != "sh" -a "$TERM" != "dumb" ] && which starship >/dev/null 2>&1 && eval "$(starship init $_SHELL)"
unset _SHELL
